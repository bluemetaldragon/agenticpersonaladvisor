{
  "name": "Python 3 Development Environment",
  "image": "://microsoft.com",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-python.debugpy"
      ]
    }
  },
  "forwardPorts": [8000],
  "portsAttributes": {
    "8000": {
      "label": "FastAPI App Server",
      "onAutoForward": "notify"
    }
  },
  "postCreateCommand": "pip install --upgrade pip && pip install -r requirements.txt"
}
